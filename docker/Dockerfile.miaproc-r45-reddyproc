# miaproc CLI runtime image - standalone publish-repo layout.
#
# Build from the public package repo root:
#
#   docker build -f docker/Dockerfile.miaproc-r45-reddyproc \
#       -t miaproc:cli-r45 .
#
# This Dockerfile is intentionally different from the artifact-workspace
# Dockerfile in the development repo: the published repo has pyproject.toml,
# src/, tests/, docs/, and examples/ at the repo root, not under 08_pkg/.

FROM rocker/r-ver:4.5.1

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-dev \
        python3-pip \
        build-essential \
        ca-certificates \
        git \
        curl \
        libxml2-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        libfontconfig1-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/miaproc-venv
ENV PATH="/opt/miaproc-venv/bin:${PATH}"

# Project-scoped R library layout for the Decision 010 / R11 preflight.
ENV MIAPROC_REPO_ROOT=/app
ENV R_LIBS_USER=/app/renv/library/R-4.5/x86_64-pc-linux-gnu
RUN mkdir -p "${R_LIBS_USER}"

COPY renv.lock /app/renv.lock

RUN R -q -e "install.packages('remotes', lib=Sys.getenv('R_LIBS_USER'), repos='https://cloud.r-project.org')" \
    && R -q -e "remotes::install_version('REddyProc', version='1.3.4', lib=Sys.getenv('R_LIBS_USER'), repos='https://cloud.r-project.org', upgrade='never')" \
    && R -q -e ".libPaths(c(Sys.getenv('R_LIBS_USER'), .libPaths())); stopifnot(packageVersion('REddyProc') == '1.3.4'); cat('REddyProc OK at', find.package('REddyProc'), '\n')"

WORKDIR /app

COPY pyproject.toml README.md LICENSE /app/
COPY src /app/src
COPY tests /app/tests
COPY docs /app/docs
COPY examples /app/examples

RUN /opt/miaproc-venv/bin/pip install --upgrade pip \
    && /opt/miaproc-venv/bin/pip install -e "/app[dev,hesseflux,reddyproc,bigquery]"

CMD ["miaproc", "--help"]
